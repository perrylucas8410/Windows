#!/bin/bash
sudo pkill -9 -f qemu-system-x86_64
sudo pkill -9 -f websockify
sudo sync && echo 3 | sudo tee /proc/sys/vm/drop_caches

echo "[SYSTEM] Starting noVNC Console..."
sudo cp /usr/share/novnc/vnc.html /usr/share/novnc/index.html 2>/dev/null
sudo /usr/bin/websockify --web /usr/share/novnc/ 8006 localhost:5900 &

# 1. Create a 20GB 'Dynamic' Data Disk if it doesn't exist
if [ ! -f "/tmp/windows/data_disk.qcow2" ]; then
    echo "[SYSTEM] Creating extra 20GB storage disk..."
    qemu-img create -f qcow2 /tmp/windows/data_disk.qcow2 20G
fi

echo "[SYSTEM] Booting Windows with Extra Storage..."
sudo qemu-system-x86_64 \
  -m 6G \
  -smp 2 \
  -enable-kvm \
  -cpu host,hv_relaxed,hv_spinlocks=0x1fff,hv_vapic,hv_time \
  -drive if=pflash,format=raw,readonly=on,file=/usr/share/OVMF/OVMF_CODE_4M.fd \
  -drive file=/tmp/windows/data.vhdx,format=vhdx,cache=writeback,aio=threads \
  -drive file=/tmp/windows/data_disk.qcow2,format=qcow2 \
  -netdev user,id=net0,hostfwd=tcp::8443-:8443 \
  -device e1000,netdev=net0 \
  -vga std \
  -vnc :0 \
  -audiodev none,id=none