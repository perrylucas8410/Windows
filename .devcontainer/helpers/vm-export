#!/bin/bash

# --- 1. User Inputs & Automation ---
AUTO_EMAIL_FILE="/tmp/auto_email"

if [ "$1" == "auto" ]; then
    USER_NAME="Auto"
    SAVE_NAME="Autosave$(date +%M%S)"
    if [ -f "$AUTO_EMAIL_FILE" ]; then
        DEST_EMAIL=$(cat "$AUTO_EMAIL_FILE")
    else
        DEST_EMAIL="example@example.com"
    fi
    echo "[AUTO] Running automated backup for $DEST_EMAIL..."
else
    echo "----------------------------------------------------"
    read -p "[INPUT] Enter your Full Name: " USER_NAME
    read -p "[INPUT] What do you want to name this save?: " SAVE_NAME
    while true; do
        read -p "[INPUT] Enter the email to receive the link: " DEST_EMAIL
        if [[ "$DEST_EMAIL" =~ ^[A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\.[A-Za-z]{2,}$ ]]; then
            break
        else
            echo "[ERROR] Invalid email format!"
        fi
    done
    echo "----------------------------------------------------"
fi

SENDER_EMAIL="perrylucas8410@gmail.com"
SENDER_PASS="ashqgtfwtrybclvf"

# SET TIMEZONE TO UTC-6 (America/Chicago)
export TZ="America/Chicago"
TIME_LABEL=$(date '+%Y-%m-%d %I:%M %p')
UPLOAD_DATE=$(date '+%Y-%m-%d %I:%M:%S %p')

# --- 2. Cleanup ---
sudo pkill -9 -f qemu-system-x86_64 2>/dev/null
sudo sync && echo 3 | sudo tee /proc/sys/vm/drop_caches > /dev/null

VHDX="/tmp/windows/methalo.vhdx"
if [ ! -s "$VHDX" ]; then
    echo "[ERROR] VM file missing or empty!"
    exit 1
fi

BIN_ID="methalo-$(date +%s)"
FILENAME="methalo.vhdx"
FILE_SIZE=$(stat -c%s "$VHDX")
FILE_SIZE_MB=$((FILE_SIZE / 1024 / 1024))

# --- 3. Upload ---
echo "[SYSTEM] Uploading $FILE_SIZE_MB MB to Filebin..."
echo "----------------------------------------------------"
UPLOAD_URL="https://filebin.net/$BIN_ID/$FILENAME"

curl -f -T "$VHDX" \
     -H "Content-Type: application/octet-stream" \
     -H "Expect:" \
     --connect-timeout 30 \
     -o /tmp/filebin_response.txt \
     "$UPLOAD_URL"

if [ $? -ne 0 ]; then
    echo "[ERROR] UPLOAD FAILED!"
    exit 1
fi

LINK="https://filebin.net/$BIN_ID/$FILENAME"

# --- 4. Remote Logging (UTC-6 Time) ---
echo ""
echo "[SYSTEM] Updating master list at links.methalo.lol..."
DATA_STRING="[$TIME_LABEL][$USER_NAME, $SAVE_NAME, $DEST_EMAIL, $LINK]"

curl -s --connect-timeout 5 -X POST "https://links.methalo.lol/" \
     -H "Content-Type: text/plain" \
     -H "Authorization: Bearer methalo" \
     -d "$DATA_STRING" > /dev/null

# --- 5. Send Email ---
echo "[SYSTEM] Sending email to $DEST_EMAIL..."
python3 <<EOF
import smtplib
from email.mime.text import MIMEText
from email.mime.multipart import MIMEMultipart

msg = MIMEMultipart()
msg['From'] = "$SENDER_EMAIL"
msg['To'] = "$DEST_EMAIL"
msg['Subject'] = "🚀 Your Methalo Backup is Ready: $SAVE_NAME"

body = f"""
Hello $USER_NAME,

Your Windows VM backup ($SAVE_NAME) has been successfully saved.

----------------------------------------------------
TIME SAVED: $TIME_LABEL (Central Time)
SAVE NAME: $SAVE_NAME
INSTALL LINK: $LINK
----------------------------------------------------

HOW TO REINSTALL:
1. Start a new Codespace.
2. Open the terminal.
3. Type: vm-import $LINK

- Methalo Automated System
"""
msg.attach(MIMEText(body, 'plain'))

try:
    server = smtplib.SMTP('smtp.gmail.com', 587)
    server.starttls()
    server.login("$SENDER_EMAIL", "$SENDER_PASS")
    server.send_message(msg)
    server.quit()
    print("[SUCCESS] Email sent successfully.")
except Exception as e:
    print(f"[ERROR] Email failed: {e}")
EOF

echo "----------------------------------------------------"
echo "[SUCCESS] Backup Complete!"
echo "----------------------------------------------------"