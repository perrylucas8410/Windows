{
    "name": "Methalo (4-core)",
    "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
    "forwardPorts": [ 8008, 8006 ],
    "portsAttributes": {
        "8008": { "label": "Holder", "onAutoForward": "notify" },
        "8006": { "label": "Console", "onAutoForward": "notify" }
    },
    "runArgs": [ "--device=/dev/kvm", "--privileged" ],
    "workspaceMount": "source=${localWorkspaceFolder},target=/workspaces/Windows,type=bind",
    "workspaceFolder": "/workspaces/Windows",
    "onCreateCommand": "sudo bash .devcontainer/4-core/onCreateCommand.sh",
    "hostRequirements": {
        "cpus": 4,
        "memory": "16gb"
    }
}
